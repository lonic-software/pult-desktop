{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pult-desktop",
  "version": "0.2.1",
  "identifier": "com.lonic.pultdesktop",
  "build": {
    "beforeDevCommand": "node scripts/fetch-pult-sidecar.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/fetch-pult-sidecar.mjs && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "pult-desktop",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "externalBin": ["binaries/pult"],
    "publisher": "Lonic Software",
    "homepage": "https://github.com/lonic-software/pult-desktop",
    "license": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Desktop companion for pult — run repository commands through a form, not flags.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
